# Copy file này thành .env.local và điền giá trị vào
# Hoặc thêm vào GitHub Secrets để deploy tự động

# Google Drive folder ID (lấy từ URL của folder)
NEXT_PUBLIC_GOOGLE_DRIVE_FOLDER_ID=

# Google API Key (tạo tại console.cloud.google.com)
# Enable: Google Drive API → Credentials → Create API Key
NEXT_PUBLIC_GOOGLE_API_KEY=

# Base path - để trống nếu dùng custom domain
# Đặt /bbm nếu deploy lên username.github.io/bbm
NEXT_PUBLIC_BASE_PATH=/bbm
